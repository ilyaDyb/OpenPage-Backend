# views.py
from rest_framework.decorators import api_view, permission_classes
from rest_framework.response import Response
from rest_framework import status
from django.conf import settings
from .models import AuthToken, User

@api_view(['POST'])
@permission_classes([])  # открытый эндпоинт, но с проверкой секрета
def confirm_auth(request):
    # 1. Проверка секретного ключа
    secret = request.headers.get('X-Secret-Key')
    if secret != settings.BOT_SECRET_KEY:
        return Response({'error': 'Forbidden'}, status=status.HTTP_403_FORBIDDEN)

    # 2. Получение данных
    telegram_id = request.data.get('telegram_id')
    token = request.data.get('token')
    if not telegram_id or not token:
        return Response({'error': 'Missing fields'}, status=status.HTTP_400_BAD_REQUEST)

    # 3. Проверка токена в БД
    try:
        auth_token = AuthToken.objects.get(token=token, is_used=False)
    except AuthToken.DoesNotExist:
        return Response({'error': 'Invalid or expired token'}, status=status.HTTP_404_NOT_FOUND)

    # 4. Привязываем telegram_id к пользователю (или создаём нового)
    user, _ = User.objects.get_or_create(telegram_id=telegram_id)
    # ... здесь можно также связать с существующим аккаунтом, если токен содержит user_id

    # 5. Помечаем токен как использованный
    auth_token.is_used = True
    auth_token.save()

    return Response({'status': 'ok'}, status=status.HTTP_200_OK)


Токен — это случайная строка, которую бэкенд генерирует в момент, когда пользователь запрашивает вход через QR. Эта строка:

Уникальна.

Имеет ограниченное время жизни (например, 5 минут).

Одноразовая (после использования теряет силу).