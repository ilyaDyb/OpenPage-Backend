upstream openpage_backend {
    server web:8000;
}

upstream openpage_frontend {
    server ${FRONTEND_UPSTREAM};
}

server {
    listen 80;
    server_name ${NGINX_SERVER_NAME};

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    http2 on;
    server_name ${NGINX_SERVER_NAME};

    ssl_certificate /etc/letsencrypt/live/${LETSENCRYPT_DOMAIN}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/${LETSENCRYPT_DOMAIN}/privkey.pem;
    ssl_session_timeout 1d;
    ssl_session_cache shared:OpenPageSSL:10m;
    ssl_session_tickets off;
    ssl_protocols TLSv1.2 TLSv1.3;
    add_header Strict-Transport-Security "max-age=31536000" always;

    client_max_body_size 50m;

    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";

    location /api/ {
        proxy_pass http://openpage_backend;
    }

    location /admin/ {
        proxy_pass http://openpage_backend;
    }

    location /media/ {
        alias /var/www/openpage/media/;
        expires 7d;
        add_header Cache-Control "public";
    }

    location /static/ {
        alias /var/www/openpage/static/;
        expires 7d;
        add_header Cache-Control "public";
    }

    location / {
        proxy_pass http://openpage_frontend;
    }
}
